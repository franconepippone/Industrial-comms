        "command": "C:/Users/ameri/.platformio/penv/Scripts/platformio.exe device monitor --environment peer_a",
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "presentation": {
            "group": "mySplitGroup",
          "reveal": "always",
          "panel": "dedicated"
        }
      },
      {
        "label": "Terminal B",
        "type": "shell",
        "command": "C:/Users/ameri/.platformio/penv/Scripts/platformio.exe device monitor --environment peer_b",
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "presentation": {
            "group": "mySplitGroup",
          "reveal": "always",
          "panel": "dedicated"
        }
      },
      {
